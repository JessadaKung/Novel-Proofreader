# Google Gemini API
LLM_PROVIDER=google
GOOGLE_API_KEY=replace-me
LLM_MODEL=gemma-4-31b-it
GOOGLE_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite
GOOGLE_RETRY_COUNT=3
GOOGLE_RETRY_DELAY_SECONDS=4
GOOGLE_TIMEOUT_SECONDS=300
DISCORD_WEBHOOK_URL=

# Web login. Strongly recommended on a public server.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-long-password
